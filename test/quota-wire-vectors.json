{
  "version": "2",
  "contract": "cail-gateway nested error and quota wire contract (2026-07-12)",
  "sync": "CANONICAL COPY lives in cail-gateway model-proxy/test/quota-wire-vectors.json; cail-client vendors a byte-identical copy at test/quota-wire-vectors.json. Both repos' tests pin this file's SHA-256 — change it in BOTH repos in one deliberate step or tests fail.",
  "header_cases": [
    {
      "name": "complete-ok",
      "producer_emits": true,
      "headers": {
        "X-CAIL-Quota-Limit": "10000000",
        "X-CAIL-Quota-Used": "630000",
        "X-CAIL-Quota-Remaining": "9370000",
        "X-CAIL-Quota-Reset": "1723200000",
        "X-CAIL-Quota-Window": "2592000",
        "X-CAIL-Quota-State": "ok"
      },
      "expect": {
        "limit": 10000000,
        "used": 630000,
        "remaining": 9370000,
        "reset": 1723200000,
        "window_seconds": 2592000,
        "state": "ok"
      }
    },
    {
      "name": "complete-stale",
      "producer_emits": true,
      "headers": {
        "X-CAIL-Quota-Limit": "10000000",
        "X-CAIL-Quota-Used": "10250000",
        "X-CAIL-Quota-Remaining": "0",
        "X-CAIL-Quota-Reset": "1724000000",
        "X-CAIL-Quota-Window": "2592000",
        "X-CAIL-Quota-State": "stale"
      },
      "expect": {
        "limit": 10000000,
        "used": 10250000,
        "remaining": 0,
        "reset": 1724000000,
        "window_seconds": 2592000,
        "state": "stale"
      }
    },
    {
      "name": "zero-used-fresh-subject",
      "producer_emits": true,
      "headers": {
        "X-CAIL-Quota-Limit": "10000000",
        "X-CAIL-Quota-Used": "0",
        "X-CAIL-Quota-Remaining": "10000000",
        "X-CAIL-Quota-Reset": "1720600000",
        "X-CAIL-Quota-Window": "2592000",
        "X-CAIL-Quota-State": "ok"
      },
      "expect": {
        "limit": 10000000,
        "used": 0,
        "remaining": 10000000,
        "reset": 1720600000,
        "window_seconds": 2592000,
        "state": "ok"
      }
    },
    {
      "name": "missing-one-header-all-or-none",
      "producer_emits": false,
      "headers": {
        "X-CAIL-Quota-Limit": "10000000",
        "X-CAIL-Quota-Used": "630000",
        "X-CAIL-Quota-Remaining": "9370000",
        "X-CAIL-Quota-Reset": "1723200000",
        "X-CAIL-Quota-Window": "2592000"
      },
      "expect": null
    },
    {
      "name": "malformed-integer",
      "producer_emits": false,
      "headers": {
        "X-CAIL-Quota-Limit": "ten-dollars",
        "X-CAIL-Quota-Used": "630000",
        "X-CAIL-Quota-Remaining": "9370000",
        "X-CAIL-Quota-Reset": "1723200000",
        "X-CAIL-Quota-Window": "2592000",
        "X-CAIL-Quota-State": "ok"
      },
      "expect": null
    },
    {
      "name": "negative-integer-never-on-wire",
      "producer_emits": false,
      "headers": {
        "X-CAIL-Quota-Limit": "10000000",
        "X-CAIL-Quota-Used": "630000",
        "X-CAIL-Quota-Remaining": "-42",
        "X-CAIL-Quota-Reset": "1723200000",
        "X-CAIL-Quota-Window": "2592000",
        "X-CAIL-Quota-State": "ok"
      },
      "expect": null
    },
    {
      "name": "unknown-state-value",
      "producer_emits": false,
      "headers": {
        "X-CAIL-Quota-Limit": "10000000",
        "X-CAIL-Quota-Used": "630000",
        "X-CAIL-Quota-Remaining": "9370000",
        "X-CAIL-Quota-Reset": "1723200000",
        "X-CAIL-Quota-Window": "2592000",
        "X-CAIL-Quota-State": "approximately"
      },
      "expect": null
    },
    {
      "name": "no-quota-headers-at-all",
      "producer_emits": false,
      "headers": {},
      "expect": null
    }
  ],
  "quota_body_cases": [
    {
      "name": "complete-quota-body",
      "body": {
        "object": "quota",
        "subject": "cail-EDGAR.TROUDT14",
        "unit": "microdollar",
        "currency": "USD",
        "window_seconds": 2592000,
        "limit": 10000000,
        "used": 630000,
        "remaining": 9370000,
        "reset": 1723200000,
        "as_of": 1720600000,
        "state": "ok",
        "enforced": true,
        "limit_usd": "10.00",
        "used_usd": "0.63",
        "remaining_usd": "9.37"
      },
      "expect": {
        "subject": "cail-EDGAR.TROUDT14",
        "limit": 10000000,
        "used": 630000,
        "remaining": 9370000,
        "reset": 1723200000,
        "window_seconds": 2592000,
        "state": "ok",
        "enforced": true,
        "as_of": 1720600000
      }
    }
  ],
  "error_cases": [
    {
      "name": "quota-unavailable-503",
      "producer": "quota_unavailable",
      "status": 503,
      "headers": {
        "content-type": "application/json",
        "x-cail-request-id": "vector-request-503",
        "x-request-id": "vector-request-503",
        "x-should-retry": "true"
      },
      "body": {
        "error": {
          "message": "We could not read your quota right now. Model calls may still work; your budget still applies.",
          "type": "server_error",
          "param": null,
          "code": "quota_unavailable"
        }
      },
      "expect_error_code": "quota_unavailable"
    },
    {
      "name": "native-quota-exceeded-429",
      "producer": "native_quota_exceeded",
      "status": 429,
      "headers": {
        "content-type": "application/json",
        "retry-after": "3600",
        "x-cail-request-id": "vector-request-quota",
        "x-request-id": "vector-request-quota",
        "x-should-retry": "false"
      },
      "body": {
        "error": {
          "message": "The CAIL model budget is exhausted for this period.",
          "type": "rate_limit_error",
          "param": null,
          "code": "quota_exceeded",
          "cail": {
            "retry_after_seconds": 3600
          }
        }
      },
      "expect_error_code": "quota_exceeded"
    },
    {
      "name": "opaque-upstream-rate-limit-429",
      "producer": "upstream_rate_limited",
      "status": 429,
      "headers": {
        "content-type": "application/json",
        "retry-after": "10",
        "x-cail-request-id": "vector-request-rate",
        "x-request-id": "vector-request-rate",
        "x-should-retry": "true"
      },
      "body": {
        "error": {
          "message": "The upstream model service is temporarily rate limited. Please retry later.",
          "type": "rate_limit_error",
          "param": null,
          "code": "upstream_rate_limited",
          "cail": {
            "retry_after_seconds": 10
          }
        }
      },
      "expect_error_code": "upstream_rate_limited"
    },
    {
      "name": "authentication-required-401",
      "producer": "authentication_required",
      "status": 401,
      "headers": {
        "content-type": "application/json",
        "www-authenticate": "Bearer realm=\"CAIL\"",
        "x-cail-request-id": "vector-request-auth",
        "x-request-id": "vector-request-auth",
        "x-should-retry": "false"
      },
      "body": {
        "error": {
          "message": "Sign in with CUNY Login.",
          "type": "authentication_error",
          "param": null,
          "code": "authentication_required",
          "cail": {
            "login_url": "/login"
          }
        }
      },
      "expect_error_code": "authentication_required"
    }
  ]
}
